---
import { siteCopy } from '@/i18n/site';
import type { BookEntry } from '@/types';

interface Props {
  books: BookEntry[];
  title: string;
}

const { books, title } = Astro.props;
---

<section class="space-y-8">
  <div class="flex flex-col gap-4 border-b border-line/80 pb-6 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="eyebrow">{siteCopy.bookshelf.title}</p>
      <h2 class="mt-3 font-serif text-3xl leading-tight text-ink sm:text-4xl">{title}</h2>
    </div>
    <p class="text-sm text-muted">{siteCopy.post.bookCountRecorded(books.length)}</p>
  </div>

  <div class="grid gap-6">
    {books.map((book, index) => (
      <article class="grid gap-5 rounded-[1.9rem] border border-line/80 bg-white/68 p-5 shadow-[0_12px_32px_rgba(15,23,42,0.04)] sm:grid-cols-[7rem_minmax(0,1fr)] sm:p-6">
        <div class="overflow-hidden rounded-[1.4rem] border border-line/80 bg-paper/70">
          {book.cover ? (
            <img src={book.cover} alt={book.title} class="h-full min-h-[9.5rem] w-full object-cover" loading="lazy" />
          ) : (
            <div class="flex min-h-[9.5rem] items-end bg-[linear-gradient(180deg,rgba(36,87,214,0.04),rgba(15,23,42,0.08))] p-4">
              <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted">#{String(index + 1).padStart(2, '0')}</span>
            </div>
          )}
        </div>

        <div>
          <div class="flex flex-wrap items-center gap-2 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-muted">
            {book.status && <span>{book.status}</span>}
            {book.language && <span>· {book.language}</span>}
          </div>
          <h3 class="mt-3 font-serif text-2xl leading-tight text-ink">
            {book.link ? <a href={book.link} target="_blank" rel="noreferrer" class="no-underline hover:text-accent">{book.title}</a> : book.title}
          </h3>

          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm text-muted">
            {book.author && <span>作者：{book.author}</span>}
            {book.publisher && <span>出版：{book.publisher}</span>}
          </div>

          {book.description && <p class="mt-4 text-sm leading-7 text-ink/85">{book.description}</p>}
          {book.review && <p class="mt-4 rounded-[1.2rem] bg-paper/75 px-4 py-3 text-sm leading-7 text-muted">{book.review}</p>}
        </div>
      </article>
    ))}
  </div>
</section>
