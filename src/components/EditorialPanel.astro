---
interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  padding?: 'normal' | 'compact';
}

const { eyebrow, title, body, padding = 'normal' } = Astro.props;
const paddingClass = padding === 'compact' ? 'p-5 sm:p-6' : 'p-6 sm:p-7';
---

<section class={`card bg-white/62 ${paddingClass}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  {title && <h2 class="mt-3 font-serif text-2xl leading-tight text-ink sm:text-[1.85rem]">{title}</h2>}
  {body && <p class="mt-3 text-sm leading-7 text-muted sm:text-[0.98rem]">{body}</p>}
  <div class={title || body ? 'mt-5' : ''}>
    <slot />
  </div>
</section>
