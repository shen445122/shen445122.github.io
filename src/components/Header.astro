---
import { siteCopy } from '@/i18n/site';

const nav = [
  { href: '/', label: siteCopy.nav.home },
  { href: '/writing', label: siteCopy.nav.writing },
  { href: '/archive', label: siteCopy.nav.archive },
  { href: '/about', label: siteCopy.nav.about }
];
---

<header class="sticky top-0 z-30 border-b border-line/70 bg-paper/92 backdrop-blur">
  <div class="container-shell flex items-center justify-between gap-6 py-4">
    <a href="/" class="no-underline">
      <div class="text-sm font-semibold uppercase tracking-[0.28em] text-accent">雨沐苍树</div>
      <div class="text-xs text-muted">{siteCopy.brand.subtitle}</div>
    </a>

    <nav aria-label={siteCopy.nav.primaryLabel}>
      <ul class="flex items-center gap-1 text-sm text-muted sm:gap-2">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="inline-flex rounded-full px-3 py-2 no-underline transition hover:bg-white hover:text-ink"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
