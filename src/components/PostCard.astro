---
import { formatPostDate, getPostTypeLabel } from '@/lib/posts';
import type { Post } from '@/types';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const badge = getPostTypeLabel(post.postType);
const href = `/writing/${post.slug}/`;
const meta = post.isBookPost ? `${post.books.length} ${post.books.length === 1 ? 'book' : 'books'}` : post.readingTime;
---

<article class="group h-full rounded-[2rem] border border-line/80 bg-white/70 p-6 shadow-[0_14px_40px_rgba(15,23,42,0.05)] transition hover:-translate-y-0.5 hover:shadow-[0_20px_50px_rgba(15,23,42,0.08)] sm:p-7">
  <div class="flex items-center gap-2 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-muted">
    <span>{badge}</span>
    <span>•</span>
    <span>{formatPostDate(post.date)}</span>
  </div>
  <h3 class="mt-4 font-serif text-2xl leading-tight text-ink transition group-hover:text-accent">
    <a href={href} class="no-underline">{post.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-muted">{post.description || post.excerpt}</p>
  <div class="mt-6 flex items-center justify-between gap-4 border-t border-line/80 pt-4 text-sm">
    <span class="text-muted">{meta}</span>
    <a href={href} class="font-medium no-underline">{post.isBookPost ? 'Open shelf →' : 'Read essay →'}</a>
  </div>
</article>
