---
import { formatPostDate, getPostTypeLabel } from '@/lib/posts';
import type { Post } from '@/types';

interface Props {
  post: Post;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const href = `/writing/${post.slug}/`;
const cta = post.isBookPost ? 'Open shelf →' : 'Read piece →';
const meta = post.isBookPost ? `${post.books.length} ${post.books.length === 1 ? 'book' : 'books'}` : post.readingTime;
const label = getPostTypeLabel(post.postType);
---

<article class={`group ${compact ? 'py-4' : 'py-6'} border-b border-line/80 last:border-b-0`}>
  <a href={href} class="grid gap-3 no-underline transition sm:grid-cols-[minmax(0,1fr)_11rem] sm:items-start sm:gap-6">
    <div>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-muted">
        <span>{label}</span>
        <span class="hidden sm:inline">·</span>
        <span>{formatPostDate(post.date)}</span>
      </div>
      <h3 class={`mt-2 font-serif leading-tight text-ink transition group-hover:text-accent ${compact ? 'text-xl sm:text-2xl' : 'text-2xl sm:text-[2rem]'}`}>
        {post.title}
      </h3>
      <p class={`mt-3 max-w-2xl text-muted ${compact ? 'text-sm leading-7' : 'text-base leading-8'}`}>
        {post.description || post.excerpt}
      </p>
    </div>
    <div class="flex flex-col gap-2 text-sm text-muted sm:items-end sm:text-right">
      <span>{meta}</span>
      <span class="font-medium text-accent">{cta}</span>
    </div>
  </a>
</article>
