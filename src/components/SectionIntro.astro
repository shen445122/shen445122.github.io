---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 font-serif text-3xl leading-tight text-ink sm:text-4xl">{title}</h2>
  {intro && <p class="mt-4 text-base leading-7 text-muted sm:text-lg">{intro}</p>}
</div>
