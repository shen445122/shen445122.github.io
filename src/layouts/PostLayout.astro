---
import { siteCopy } from '@/i18n/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import BookShelf from '@/components/BookShelf.astro';
import EditorialPanel from '@/components/EditorialPanel.astro';
import MetadataChips from '@/components/MetadataChips.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import { formatPostDate, getPostTypeDescription, getPostTypeLabel } from '@/lib/posts';
import type { HeadingLink, Post } from '@/types';

interface Props {
  post: Post;
  Content: any;
  headings?: HeadingLink[];
}

const { post, Content, headings = [] } = Astro.props;
const hasEssayBody = post.body.trim().length > 0;
const hasSections = headings.length > 0;
const typeLabel = getPostTypeLabel(post.postType);
const typeDescription = getPostTypeDescription(post.postType);
const metadata = [typeLabel, formatPostDate(post.date), post.readingTime, `${post.textLength} ${siteCopy.labels.chars}`];
const archiveSummary = `${post.year} · ${post.category}`;
const entryPrompt = siteCopy.postLayout.readingPrompt[post.postType];
const closingLinks = [
  { href: '/writing', label: siteCopy.postLayout.returnToWritingTable },
  { href: '/archive', label: siteCopy.postLayout.browseYearArchive(post.year) }
];
---

<SiteLayout title={post.title} description={post.description || post.excerpt}>
  <section class="container-shell py-16 sm:py-20">
    <div class="mx-auto max-w-5xl border-b border-line/80 pb-10">
      <a href="/writing" class="text-sm font-medium no-underline">{siteCopy.postLayout.backToWriting}</a>
      <p class="eyebrow mt-8">{archiveSummary}</p>
      <h1 class="mt-4 max-w-4xl font-serif text-4xl leading-tight text-ink sm:text-5xl lg:text-6xl">
        {post.title}
      </h1>
      <p class="article-lede mt-6 max-w-3xl text-lg leading-8 text-muted sm:text-xl">
        {post.description || post.excerpt}
      </p>
      <div class="mt-8 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <MetadataChips items={metadata} />
        {post.tags.length > 0 && <MetadataChips items={post.tags.map((tag) => `#${tag}`)} size="small" />}
      </div>
    </div>
  </section>

  <section class="container-shell pb-20">
    <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[16rem_minmax(0,1fr)] xl:grid-cols-[17rem_minmax(0,44rem)]">
      <aside class="space-y-6 text-sm text-muted lg:sticky lg:top-24 lg:self-start">
        <EditorialPanel eyebrow={siteCopy.postLayout.atAGlance} title={typeLabel} body={typeDescription} padding="compact">
          <dl class="space-y-4 text-sm leading-7 text-muted">
            <div>
              <dt class="eyebrow">{siteCopy.postLayout.published}</dt>
              <dd class="mt-1">{formatPostDate(post.date)}</dd>
            </div>
            <div>
              <dt class="eyebrow">{siteCopy.postLayout.shape}</dt>
              <dd class="mt-1">{post.readingTime} · {post.textLength} {siteCopy.labels.chars}</dd>
            </div>
            <div>
              <dt class="eyebrow">{siteCopy.postLayout.archive}</dt>
              <dd class="mt-1">{siteCopy.postLayout.archiveFiled(post.year, post.category)}</dd>
            </div>
            {post.isBookPost && (
              <div>
                <dt class="eyebrow">{siteCopy.postLayout.shelf}</dt>
                <dd class="mt-1">{siteCopy.postLayout.shelfCount(post.books.length)}</dd>
              </div>
            )}
          </dl>
        </EditorialPanel>

        <EditorialPanel eyebrow={siteCopy.postLayout.readingNote} body={entryPrompt} padding="compact" />

        {hasSections && (
          <EditorialPanel eyebrow={siteCopy.postLayout.sectionMap} padding="compact">
            <TableOfContents headings={headings} />
          </EditorialPanel>
        )}
      </aside>

      <div class="space-y-8">
        <EditorialPanel
          eyebrow={siteCopy.postLayout.editorialPreface}
          title={siteCopy.postLayout.quieterFrame}
          body={siteCopy.postLayout.quieterFrameBody}
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-[1.4rem] border border-line/70 bg-paper/75 px-4 py-4">
              <p class="eyebrow">{siteCopy.postLayout.thisPieceIsDoing}</p>
              <p class="mt-2 text-sm leading-7 text-muted">{typeDescription}</p>
            </div>
            <div class="rounded-[1.4rem] border border-line/70 bg-paper/75 px-4 py-4">
              <p class="eyebrow">{siteCopy.postLayout.bestWayIn}</p>
              <p class="mt-2 text-sm leading-7 text-muted">{entryPrompt}</p>
            </div>
          </div>
        </EditorialPanel>

        {post.isBookPost ? <BookShelf books={post.books} title={post.title} /> : null}

        {hasEssayBody ? (
          <article class="card bg-white/74 px-6 py-8 sm:px-10 sm:py-12">
            <div class="mb-8 flex flex-col gap-3 border-b border-line/70 pb-6 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
              <span>{siteCopy.postLayout.archiveKeptAs(typeLabel)}</span>
              {hasSections && <span class="text-ink/70">{siteCopy.post.sectionsMappedCount(headings.length)}</span>}
            </div>
            <div class="prose-shell article-flow article-rhythm">
              <Content />
            </div>
          </article>
        ) : null}

        <EditorialPanel eyebrow={siteCopy.postLayout.continueBrowsing} title={siteCopy.postLayout.stayInsideArchive} padding="normal">
          <div class="flex flex-wrap gap-3 text-sm">
            {closingLinks.map((item) => (
              <a href={item.href} class="rounded-full border border-line bg-white/80 px-4 py-2 font-medium text-ink no-underline hover:bg-paper">
                {item.label}
              </a>
            ))}
          </div>
          <p class="mt-4 text-sm leading-7 text-muted break-all">{siteCopy.labels.source}: {post.legacyPath}</p>
        </EditorialPanel>
      </div>
    </div>
  </section>
</SiteLayout>
