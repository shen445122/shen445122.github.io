---
import { siteCopy } from '@/i18n/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import SectionIntro from '@/components/SectionIntro.astro';

const principles = siteCopy.aboutPage.principles;
const sections = siteCopy.aboutPage.sections;
---

<SiteLayout title={siteCopy.aboutPage.title} description={siteCopy.aboutPage.description}>
  <section class="container-shell py-16 sm:py-20">
    <SectionIntro
      eyebrow={siteCopy.aboutPage.eyebrow}
      title={siteCopy.aboutPage.heading}
      intro={siteCopy.aboutPage.intro}
    />

    <div class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.9fr)]">
      <div class="space-y-6 rounded-[2rem] border border-line/80 bg-white/68 p-7 shadow-[0_14px_36px_rgba(15,23,42,0.04)] sm:p-8">
        {sections.map((section) => (
          <section class="border-b border-line/70 pb-6 last:border-b-0 last:pb-0">
            <h2 class="font-serif text-2xl leading-tight text-ink">{section.heading}</h2>
            <p class="mt-4 text-base leading-8 text-muted">{section.text}</p>
          </section>
        ))}
      </div>

      <aside class="space-y-5 rounded-[2rem] border border-line/80 bg-white/58 p-7 shadow-[0_12px_30px_rgba(15,23,42,0.04)] sm:p-8">
        <p class="eyebrow">{siteCopy.aboutPage.principlesEyebrow}</p>
        {principles.map((principle) => (
          <div class="border-b border-line/70 pb-5 last:border-b-0 last:pb-0">
            <h3 class="font-serif text-xl leading-tight text-ink">{principle.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted">{principle.body}</p>
          </div>
        ))}
      </aside>
    </div>
  </section>
</SiteLayout>
