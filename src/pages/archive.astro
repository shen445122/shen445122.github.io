---
import { siteCopy, joinPhrases } from '@/i18n/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import EditorialPanel from '@/components/EditorialPanel.astro';
import MetadataChips from '@/components/MetadataChips.astro';
import PostListItem from '@/components/PostListItem.astro';
import { groupPostsByType, getAllPosts } from '@/lib/posts';

const posts = await getAllPosts();
const groupedByType = groupPostsByType(posts);
const grouped = Object.entries(
  posts.reduce<Record<string, typeof posts>>((acc, post) => {
    acc[post.year] ??= [];
    acc[post.year].push(post);
    return acc;
  }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));

const yearAnchors = grouped.map(([year]) => ({ year, href: `#year-${year}` }));
const stats = [
  siteCopy.post.yearsCount(grouped.length),
  siteCopy.post.totalPiecesCount(posts.length),
  siteCopy.post.typeCount.essay(groupedByType.essay.length),
  siteCopy.post.typeCount.note(groupedByType.note.length),
  siteCopy.post.typeCount.readingList(groupedByType['reading-list'].length)
];
---

<SiteLayout title={siteCopy.archivePage.title} description={siteCopy.archivePage.description}>
  <section class="container-shell py-16 sm:py-20">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_19rem] lg:items-start">
      <div>
        <p class="eyebrow">{siteCopy.archivePage.eyebrow}</p>
        <h1 class="mt-4 max-w-4xl font-serif text-4xl leading-tight text-ink sm:text-5xl lg:text-6xl">
          {siteCopy.archivePage.heading}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-muted sm:text-xl">{siteCopy.archivePage.intro}</p>
        <div class="mt-8">
          <MetadataChips items={stats} />
        </div>
      </div>

      <EditorialPanel
        eyebrow={siteCopy.archivePage.usePageEyebrow}
        title={siteCopy.archivePage.usePageTitle}
        body={siteCopy.archivePage.usePageBody}
      >
        <div class="flex flex-wrap gap-2">
          {yearAnchors.map((item) => (
            <a href={item.href} class="rounded-full border border-line bg-white/80 px-3 py-1.5 text-sm font-medium text-ink no-underline hover:bg-paper">
              {item.year}
            </a>
          ))}
        </div>
      </EditorialPanel>
    </div>
  </section>

  <section class="container-shell pb-20">
    <div class="space-y-8">
      {grouped.map(([year, yearPosts]) => {
        const typeCounts = [
          { count: yearPosts.filter((post) => post.postType === 'essay').length, label: siteCopy.post.typeCount.essay },
          { count: yearPosts.filter((post) => post.postType === 'note').length, label: siteCopy.post.typeCount.note },
          { count: yearPosts.filter((post) => post.postType === 'reading-list').length, label: siteCopy.post.typeCount.readingList }
        ]
          .filter((item) => item.count > 0)
          .map((item) => item.label(item.count));
        const categories = Array.from(new Set(yearPosts.map((post) => post.category)));

        return (
          <section id={`year-${year}`} class="card bg-white/62 p-6 sm:p-8">
            <div class="flex flex-col gap-4 border-b border-line/80 pb-5 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl">
                <p class="eyebrow">{siteCopy.labels.archiveYear}</p>
                <h2 class="mt-3 font-serif text-3xl text-ink sm:text-[2.3rem]">{year}</h2>
                <p class="mt-3 text-sm leading-7 text-muted">
                  {siteCopy.archivePage.entriesPreserved(yearPosts.length, joinPhrases(categories))}
                </p>
              </div>
              <div class="flex flex-wrap gap-2 text-sm text-muted lg:justify-end">
                <MetadataChips items={typeCounts} size="small" />
              </div>
            </div>

            <div class="mt-3">
              {yearPosts.map((post) => <PostListItem post={post} compact />)}
            </div>
          </section>
        );
      })}
    </div>
  </section>
</SiteLayout>
