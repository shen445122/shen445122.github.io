---
import { siteCopy } from '@/i18n/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import PostCard from '@/components/PostCard.astro';
import PostListItem from '@/components/PostListItem.astro';
import { getHomepageFeatured, getLatestPosts } from '@/lib/posts';

const featured = await getHomepageFeatured(3);
const latest = await getLatestPosts(6);
const [lead, ...supporting] = featured;
---

<SiteLayout title={siteCopy.home.title} description={siteCopy.home.description}>
  <section class="container-shell py-16 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
      <div>
        <p class="eyebrow">{siteCopy.home.eyebrow}</p>
        <h1 class="mt-5 max-w-4xl font-serif text-5xl leading-[1.04] text-ink sm:text-6xl lg:text-7xl">
          {siteCopy.home.heading}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-muted sm:text-xl">{siteCopy.home.intro}</p>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-muted">{siteCopy.home.note}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/writing" class="rounded-full bg-accent px-5 py-3 text-sm font-medium text-white no-underline hover:bg-accent/90">{siteCopy.home.browseWriting}</a>
          <a href="/about" class="rounded-full border border-line bg-white/70 px-5 py-3 text-sm font-medium text-ink no-underline hover:bg-white">{siteCopy.home.aboutLudwig}</a>
        </div>
      </div>

      <aside class="rounded-[2rem] border border-line/80 bg-white/65 p-6 shadow-[0_12px_34px_rgba(15,23,42,0.04)]">
        <p class="eyebrow">{siteCopy.home.editorialNote}</p>
        <p class="mt-4 font-serif text-2xl leading-tight text-ink">{siteCopy.home.editorialTitle}</p>
        <p class="mt-4 text-sm leading-7 text-muted">{siteCopy.home.editorialBody}</p>
        <div class="mt-5 border-t border-line/70 pt-5 text-sm leading-7 text-muted">
          <p>{siteCopy.labels.bestEntryPoints}：</p>
          <ul class="mt-2 space-y-2 pl-5 text-ink/85">
            {siteCopy.home.entryPaths.map((path) => <li>{path}</li>)}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="container-shell pb-8">
    <div class="grid gap-8 border-y border-line/80 py-8 md:grid-cols-3">
      {siteCopy.home.themes.map((theme) => (
        <div class="md:px-2">
          <h2 class="font-serif text-[1.75rem] leading-tight text-ink">{theme.title}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{theme.body}</p>
        </div>
      ))}
    </div>
  </section>

  {lead && (
    <section class="container-shell py-14">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionIntro
          eyebrow={siteCopy.home.featuredEyebrow}
          title={siteCopy.home.featuredTitle}
          intro={siteCopy.home.featuredIntro}
        />
        <a href="/archive" class="text-sm font-medium no-underline">{siteCopy.home.viewArchive}</a>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1.45fr)_minmax(0,1fr)]">
        <article class="rounded-[2.2rem] border border-line/80 bg-white/72 p-7 shadow-[0_18px_45px_rgba(15,23,42,0.05)] sm:p-9">
          <p class="eyebrow">{lead.label}</p>
          <h2 class="mt-4 max-w-3xl font-serif text-4xl leading-tight text-ink sm:text-5xl">
            <a href={`/writing/${lead.post.slug}/`} class="no-underline hover:text-accent">{lead.post.title}</a>
          </h2>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-muted">{lead.note}</p>
          <p class="mt-5 max-w-2xl text-base leading-8 text-muted sm:text-lg">
            {lead.post.description || lead.post.excerpt}
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4 text-sm text-muted">
            <span>{lead.post.category}</span>
            <span>·</span>
            <span>{lead.post.readingTime}</span>
          </div>
        </article>

        <div class="rounded-[2.2rem] border border-line/80 bg-white/55 px-6 py-4 shadow-[0_14px_40px_rgba(15,23,42,0.04)] sm:px-8 sm:py-5">
          {supporting.map((item) => (
            <div class="border-b border-line/70 py-5 first:pt-2 last:border-b-0 last:pb-2">
              <p class="eyebrow">{item.label}</p>
              <p class="mt-2 text-sm leading-7 text-muted">{item.note}</p>
              <PostListItem post={item.post} compact />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="container-shell py-14">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <SectionIntro
        eyebrow={siteCopy.home.latestEyebrow}
        title={siteCopy.home.latestTitle}
        intro={siteCopy.home.latestIntro}
      />
      <a href="/writing" class="text-sm font-medium no-underline">{siteCopy.home.browseAllWriting}</a>
    </div>

    <div class="mt-8 grid gap-8 xl:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
      <div class="rounded-[2.2rem] border border-line/80 bg-white/55 px-6 py-4 shadow-[0_14px_40px_rgba(15,23,42,0.04)] sm:px-8 sm:py-5">
        {latest.slice(0, 4).map((post) => <PostListItem post={post} />)}
      </div>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-1">
        {latest.slice(4).map((post) => <PostCard post={post} />)}
      </div>
    </div>

    <div class="mt-10 grid gap-6 border-t border-line/70 pt-8 md:grid-cols-2">
      <div>
        <p class="eyebrow">{siteCopy.home.whyExists}</p>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-muted">{siteCopy.home.whyExistsBody}</p>
      </div>
      <div>
        <p class="eyebrow">{siteCopy.home.howToUse}</p>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-muted">{siteCopy.home.howToUseBody}</p>
      </div>
    </div>
  </section>
</SiteLayout>
