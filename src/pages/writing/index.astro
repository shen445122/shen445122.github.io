---
import SiteLayout from '@/layouts/SiteLayout.astro';
import EditorialPanel from '@/components/EditorialPanel.astro';
import PostCard from '@/components/PostCard.astro';
import PostTypeSection from '@/components/PostTypeSection.astro';
import MetadataChips from '@/components/MetadataChips.astro';
import { getAllPosts, getHomepageFeatured, groupPostsByType } from '@/lib/posts';

const posts = await getAllPosts();
const featured = await getHomepageFeatured(3);
const grouped = groupPostsByType(posts);
const years = Array.from(new Set(posts.map((post) => post.year))).sort((a, b) => Number(b) - Number(a));
const categories = Array.from(new Set(posts.map((post) => post.category)));
const totalChars = posts.reduce((sum, post) => sum + post.textLength, 0);
const stats = [
  `${posts.length} pieces`,
  `${years.length} years`,
  `${categories.length} recurring themes`,
  `${Math.max(1, Math.round(totalChars / 900))} slow reading sessions`
];
---

<SiteLayout title="Writing" description="Curated entry points into Ludwig Shen’s essays, notes, and reading lists.">
  <section class="container-shell py-16 sm:py-20">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start">
      <div>
        <p class="eyebrow">Writing</p>
        <h1 class="mt-4 max-w-4xl font-serif text-4xl leading-tight text-ink sm:text-5xl lg:text-6xl">
          A curated writing table, not just a reverse-chronological list.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-muted sm:text-xl">
          The archive is easier to enter when grouped by reading posture: long essays when you want argument, notes when you want a sharp return,
          and shelves when you want influences instead of conclusions.
        </p>
        <div class="mt-8">
          <MetadataChips items={stats} />
        </div>
      </div>

      <EditorialPanel
        eyebrow="How to browse"
        title="Three entry habits"
        body="Start from the piece shape that matches your energy, then move outward by year or category once you know the voice."
      >
        <ul class="space-y-3 pl-5 text-sm leading-7 text-ink/85">
          <li>Open an essay when you want Ludwig’s full method and pacing.</li>
          <li>Use notes as revisitable fragments for study, work, and life questions.</li>
          <li>Use reading lists to see what the archive reads alongside what it claims.</li>
        </ul>
      </EditorialPanel>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="container-shell pb-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-3xl">
          <p class="eyebrow">Start here</p>
          <h2 class="mt-3 font-serif text-3xl leading-tight text-ink sm:text-4xl">Curated entry points into the archive</h2>
          <p class="mt-4 text-base leading-7 text-muted sm:text-lg">
            These pieces were chosen as strong ways into Ludwig’s concerns, not merely because they happen to be recent.
          </p>
        </div>
        <a href="/archive" class="text-sm font-medium no-underline">Browse archive by year →</a>
      </div>

      <div class="mt-8 grid gap-6 xl:grid-cols-3">
        {featured.map((item) => (
          <div class="space-y-4">
            <EditorialPanel eyebrow={item.label} body={item.note} padding="compact" />
            <PostCard post={item.post} />
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="container-shell py-10">
    <div class="grid gap-8">
      <PostTypeSection
        type="essay"
        title="Essays for slower reading"
        intro="The longer pieces where the archive is most architectural: method, restraint, technical work, and interior stance developed across sections."
        posts={grouped.essay}
      />
      <PostTypeSection
        type="note"
        title="Notes for sharper return visits"
        intro="Shorter entries and compact reflections. Useful when you want a distilled stance or a piece that can be reread in one sitting."
        posts={grouped.note}
      />
      <PostTypeSection
        type="reading-list"
        title="Reading lists and shelves"
        intro="Books and brief comments arranged as influences, annotations, and snapshots of taste rather than conventional reviews."
        posts={grouped['reading-list']}
      />
    </div>
  </section>
</SiteLayout>
