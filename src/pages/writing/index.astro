---
import { siteCopy } from '@/i18n/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import EditorialPanel from '@/components/EditorialPanel.astro';
import PostCard from '@/components/PostCard.astro';
import PostTypeSection from '@/components/PostTypeSection.astro';
import MetadataChips from '@/components/MetadataChips.astro';
import { getAllPosts, getHomepageFeatured, groupPostsByType } from '@/lib/posts';

const posts = await getAllPosts();
const featured = await getHomepageFeatured(3);
const grouped = groupPostsByType(posts);
const years = Array.from(new Set(posts.map((post) => post.year))).sort((a, b) => Number(b) - Number(a));
const categories = Array.from(new Set(posts.map((post) => post.category)));
const totalChars = posts.reduce((sum, post) => sum + post.textLength, 0);
const stats = [
  siteCopy.post.piecesCount(posts.length),
  siteCopy.post.yearsCount(years.length),
  siteCopy.post.recurringThemesCount(categories.length),
  siteCopy.post.slowReadingSessionsCount(Math.max(1, Math.round(totalChars / 900)))
];
---

<SiteLayout title={siteCopy.writingPage.title} description={siteCopy.writingPage.description}>
  <section class="container-shell py-16 sm:py-20">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start">
      <div>
        <p class="eyebrow">{siteCopy.writingPage.eyebrow}</p>
        <h1 class="mt-4 max-w-4xl font-serif text-4xl leading-tight text-ink sm:text-5xl lg:text-6xl">
          {siteCopy.writingPage.heading}
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-muted sm:text-xl">{siteCopy.writingPage.intro}</p>
        <div class="mt-8">
          <MetadataChips items={stats} />
        </div>
      </div>

      <EditorialPanel
        eyebrow={siteCopy.writingPage.howToBrowseEyebrow}
        title={siteCopy.writingPage.howToBrowseTitle}
        body={siteCopy.writingPage.howToBrowseBody}
      >
        <ul class="space-y-3 pl-5 text-sm leading-7 text-ink/85">
          {siteCopy.writingPage.habits.map((habit) => <li>{habit}</li>)}
        </ul>
      </EditorialPanel>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="container-shell pb-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-3xl">
          <p class="eyebrow">{siteCopy.writingPage.startHereEyebrow}</p>
          <h2 class="mt-3 font-serif text-3xl leading-tight text-ink sm:text-4xl">{siteCopy.writingPage.startHereTitle}</h2>
          <p class="mt-4 text-base leading-7 text-muted sm:text-lg">{siteCopy.writingPage.startHereIntro}</p>
        </div>
        <a href="/archive" class="text-sm font-medium no-underline">{siteCopy.writingPage.browseArchiveByYear}</a>
      </div>

      <div class="mt-8 grid gap-6 xl:grid-cols-3">
        {featured.map((item) => (
          <div class="space-y-4">
            <EditorialPanel eyebrow={item.label} body={item.note} padding="compact" />
            <PostCard post={item.post} />
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="container-shell py-10">
    <div class="grid gap-8">
      <PostTypeSection
        type="essay"
        title={siteCopy.writingPage.essaySectionTitle}
        intro={siteCopy.writingPage.essaySectionIntro}
        posts={grouped.essay}
      />
      <PostTypeSection
        type="note"
        title={siteCopy.writingPage.noteSectionTitle}
        intro={siteCopy.writingPage.noteSectionIntro}
        posts={grouped.note}
      />
      <PostTypeSection
        type="reading-list"
        title={siteCopy.writingPage.readingListSectionTitle}
        intro={siteCopy.writingPage.readingListSectionIntro}
        posts={grouped['reading-list']}
      />
    </div>
  </section>
</SiteLayout>
